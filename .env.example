# ── AWS ────────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=eu-central-1
AWS_ACCOUNT_ID=123456789012

# ── S3 buckets ─────────────────────────────────────────────────────────────────
AWS_S3_RAW_BUCKET=pred-maint-raw
AWS_S3_PROCESSED_BUCKET=pred-maint-processed

# ── ML model ───────────────────────────────────────────────────────────────────
# Set after running `make train` — value is written to .model_version automatically
MODEL_S3_KEY=models/xgb_20240101_120000.json

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=localdev
DATABASE_URL=postgresql://pred_maint:localdev@localhost:5432/pred_maint

# ── MLflow ─────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5001

# ── Dashboard ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Glue (set before running infra/setup_glue.py) ─────────────────────────────
GLUE_ROLE_ARN=arn:aws:iam::123456789012:role/AWSGlueServiceRole-PredMaint
